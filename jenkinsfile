pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Arul123-gif/ETL-FRAMEWORK.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'pip install -r requirements.txt'
            }
        }

        stage('Run Pytest') {
            steps {
                script {
                    def timestamp = new Date().format("yyyyMMdd_HHmmss")

                    bat """
                    pytest tests ^
                    --html=reports/report_${timestamp}.html ^
                    --self-contained-html
                    """
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'reports/*.html'
        }
    }
}